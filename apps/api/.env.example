NODE_ENV=development
PORT=4000

# PostgreSQL connection string (Supabase Transaction Mode / Supavisor - port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database (Supabase Session Mode - port 5432). Used for migrations.
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Generate secrets: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-use-openssl-rand-base64-32
JWT_REFRESH_SECRET=change-me-use-openssl-rand-base64-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000
